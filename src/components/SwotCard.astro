---
// ===== SwotCard.astro — Side-by-side Strengths / Weaknesses cards =====
// Usage in MDX:
//   <SwotCard title="使用 MDX 写技术内容"
//     strengths='[{"label":"复用组件","desc":"图表、卡片、流程块一次开发，多篇复用"},...]'
//     weaknesses='[{"label":"复杂度上升","desc":"构建链路与运行时依赖更重"},...]' />
export interface Props {
  title: string;
  strengths: string;  // JSON: { label: string; desc: string }[]
  weaknesses: string; // JSON: { label: string; desc: string }[]
}

const { title, strengths, weaknesses } = Astro.props;
const sItems = JSON.parse(strengths) as { label: string; desc: string }[];
const wItems = JSON.parse(weaknesses) as { label: string; desc: string }[];
---

<div class="not-prose my-8">
  {title && (
    <h4 class="text-sm font-semibold text-zinc-800 dark:text-slate-200 mb-4">{title}</h4>
  )}
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {/* Strengths Column */}
    <div class="rounded-2xl p-5 relative overflow-hidden" style="background: #f0fdf4;">
      <div class="dark:hidden absolute top-3 right-4 text-[80px] font-bold leading-none select-none" style="color: #bbf7d0;">S</div>
      <div class="hidden dark:block absolute top-3 right-4 text-[80px] font-bold leading-none select-none" style="color: #064e3b20;">S</div>
      <h5 class="relative text-xs font-semibold uppercase tracking-wider text-green-800 dark:text-green-400 mb-4">Strengths</h5>
      <div class="relative space-y-3">
        {sItems.map((item) => (
          <div>
            <p class="text-sm font-medium text-green-900 dark:text-green-300">{item.label}</p>
            <p class="text-xs text-green-700/70 dark:text-green-400/60 mt-0.5">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Weaknesses Column */}
    <div class="rounded-2xl p-5 relative overflow-hidden" style="background: #fef2f2;">
      <div class="dark:hidden absolute top-3 right-4 text-[80px] font-bold leading-none select-none" style="color: #fecaca;">W</div>
      <div class="hidden dark:block absolute top-3 right-4 text-[80px] font-bold leading-none select-none" style="color: #7f1d1d20;">W</div>
      <h5 class="relative text-xs font-semibold uppercase tracking-wider text-red-800 dark:text-red-400 mb-4">Weaknesses</h5>
      <div class="relative space-y-3">
        {wItems.map((item) => (
          <div>
            <p class="text-sm font-medium text-red-900 dark:text-red-300">{item.label}</p>
            <p class="text-xs text-red-700/70 dark:text-red-400/60 mt-0.5">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
