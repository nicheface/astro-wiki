---
// ===== SwotCard.astro — Side-by-side Strengths / Weaknesses card =====
export interface Props {
  title: string;
  strengths: string;
  weaknesses: string;
}

const { title, strengths, weaknesses } = Astro.props;
const sItems = JSON.parse(strengths) as { label: string; desc: string }[];
const wItems = JSON.parse(weaknesses) as { label: string; desc: string }[];
---

<div class="not-prose my-8 rounded-2xl border border-zinc-200/60 dark:border-slate-700/60 overflow-hidden bg-white dark:bg-slate-900">
  {/* Title */}
  <div class="px-5 py-3 bg-zinc-50 dark:bg-slate-800/50 border-b border-zinc-200/60 dark:border-slate-700/60 text-center">
    <h4 class="text-sm font-semibold text-zinc-800 dark:text-slate-200">{title}</h4>
  </div>

  {/* Body with two inner cards */}
  <div class="p-4 grid grid-cols-1 sm:grid-cols-2 gap-4">
    {/* Strengths */}
    <div class="rounded-2xl p-5 relative overflow-hidden bg-green-50 dark:bg-green-950">
      <div class="dark:hidden absolute top-2 right-3 text-[64px] font-bold leading-none select-none text-green-200">S</div>
      <div class="hidden dark:block absolute top-2 right-3 text-[64px] font-bold leading-none select-none text-green-900/20">S</div>
      <h5 class="relative text-base font-bold text-green-900 dark:text-green-300 mb-3 pb-3 border-b border-green-200 dark:border-green-800/50">Strengths</h5>
      <div class="relative space-y-4">
        {sItems.map((item) => (
          <div>
            <p class="text-sm font-semibold text-green-900 dark:text-green-200">{item.label}</p>
            <p class="text-xs text-green-700/70 dark:text-green-400/50 mt-0.5 leading-relaxed ml-4">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>

    {/* Weaknesses */}
    <div class="rounded-2xl p-5 relative overflow-hidden bg-red-50 dark:bg-red-950">
      <div class="dark:hidden absolute top-2 right-3 text-[64px] font-bold leading-none select-none text-red-200">W</div>
      <div class="hidden dark:block absolute top-2 right-3 text-[64px] font-bold leading-none select-none text-red-900/20">W</div>
      <h5 class="relative text-base font-bold text-red-900 dark:text-red-300 mb-3 pb-3 border-b border-red-200 dark:border-red-800/50">Weaknesses</h5>
      <div class="relative space-y-4">
        {wItems.map((item) => (
          <div>
            <p class="text-sm font-semibold text-red-900 dark:text-red-200">{item.label}</p>
            <p class="text-xs text-red-700/70 dark:text-red-400/50 mt-0.5 leading-relaxed ml-4">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
