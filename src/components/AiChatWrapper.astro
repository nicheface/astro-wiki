---
// ===== AiChatWrapper.astro =====
// Hydrates the AiChat React component on page load.
// Passes page context so the AI knows what the user is reading.
import AiChat from "./AiChat";

export interface Props {
  pageTitle?: string;
  pageDescription?: string;
}

const { pageTitle = "", pageDescription = "" } = Astro.props;
---

<AiChat
  client:load
  pageTitle={pageTitle}
  pageDescription={pageDescription}
/>
