---
// ===== ArticleTimeline.astro — Left sidebar: articles grouped by year =====
import { articles } from "../data/articles";
import { getLabel } from "../data/tags";

export interface Props {
  currentHref?: string;
}

const { currentHref } = Astro.props;

// Group by year
const byYear = new Map<string, typeof articles>();
articles.forEach((a) => {
  const year = a.date.slice(0, 4);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(a);
});

// Sort years descending
const years = Array.from(byYear.keys()).sort((a, b) => Number(b) - Number(a));
---

<aside class="w-56 shrink-0 hidden lg:block">
  <div class="sticky top-20 pr-6 max-h-[calc(100vh-6rem)] overflow-y-auto">
    <h4 class="text-[10px] font-semibold uppercase tracking-widest text-zinc-400 mb-4">
      全部笔记
    </h4>

    <nav class="space-y-5">
      {
        years.map((year) => (
          <div>
            <div class="flex items-center gap-2 mb-2">
              <span class="w-1.5 h-1.5 rounded-full bg-zinc-300" />
              <span class="text-xs font-semibold text-zinc-500">{year}</span>
            </div>
            <ul class="space-y-0.5">
              {byYear.get(year)!.map((a) => {
                const isActive = currentHref === a.href;
                return (
                  <li>
                    <a
                      href={a.href}
                      class={`
                        block text-sm py-1 pl-4 border-l transition-all duration-200
                        ${isActive
                          ? "border-blue-500 text-blue-600 font-medium"
                          : "border-zinc-200 text-zinc-500 hover:border-zinc-400 hover:text-zinc-700"
                        }
                      `}
                    >
                      {a.title}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))
      }
    </nav>
  </div>
</aside>
