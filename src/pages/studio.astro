---
// ===== Studio.astro — AI Studio (personal tool) =====
import Layout from "../layouts/Layout.astro";
import Studio from "../components/Studio";
import { readFileSync, readdirSync } from "node:fs";
import { join } from "node:path";

interface ArticleData {
  title: string;
  description: string;
  href: string;
  content: string;
  type: "article" | "doc";
  filename: string;
}

function cleanMdxForAI(raw: string): string {
  let text = raw;
  text = text.replace(/^---[\s\S]*?---\n?/, "");
  text = text.replace(/^import\s+.*$/gm, "");
  text = text.replace(/\{\/\*\s*[\s\S]*?\*\/\}/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*[^>]*?\/\s*>/g, "");
  text = text.replace(/<\/[A-Z][A-Za-z]*\s*>/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*\s[^>]*?>/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*>/g, "");
  text = text.replace(/\{[^}]*?\}/g, "");
  text = text.replace(/\n{3,}/g, "\n\n");
  text = text.replace(/^\s*\n/gm, "");
  return text.trim();
}

// ----- Load MDX articles -----
const allItems: ArticleData[] = [];
const pagesDir = join(process.cwd(), "src", "pages");

try {
  const files = readdirSync(pagesDir).filter((f) => f.endsWith(".mdx"));
  for (const file of files) {
    const text = readFileSync(join(pagesDir, file), "utf-8");
    const fmMatch = text.match(/^---\r?\n([\s\S]*?)\r?\n---/);
    if (!fmMatch) continue;

    const fm = fmMatch[1];
    const titleMatch = fm.match(/title:\s*["'](.+?)["']/);
    const descMatch = fm.match(/description:\s*["'](.+?)["']/);
    const hrefMatch = fm.match(/currentHref:\s*["'](.+?)["']/);

    allItems.push({
      title: titleMatch?.[1] || file.replace(/\.mdx$/, ""),
      description: descMatch?.[1] || "",
      href: hrefMatch?.[1] || "",
      content: cleanMdxForAI(text),
      type: "article",
      filename: file,
    });
  }
} catch {}

// ----- Load project reference docs (for article generator context) -----
const projectDocs = [
  { filename: "README.md", title: "README" },
  { filename: "PROJECT_SPEC.md", title: "项目规范 (PROJECT_SPEC)" },
  { filename: "NOTE_WRITING_GUIDE.md", title: "笔记编写原则" },
];

const referenceDocs: { title: string; content: string }[] = [];
for (const doc of projectDocs) {
  try {
    referenceDocs.push({
      title: doc.title,
      content: readFileSync(join(process.cwd(), doc.filename), "utf-8"),
    });
  } catch {}
}

const apiKey = import.meta.env.PUBLIC_DEEPSEEK_API_KEY || "";
---

<Layout title="Studio" description="AI-powered article generator & knowledge Q&A">
  <Studio
    itemsJson={JSON.stringify(allItems)}
    referenceDocsJson={JSON.stringify(referenceDocs)}
    apiKey={apiKey}
    client:load
  />
</Layout>
