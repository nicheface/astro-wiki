---
// ===== Studio.astro — AI Studio (personal tool) =====
// Build-time: reads all MDX articles + writing guide from disk.
// Cleans JSX noise from article content before passing to AI.
// Client-side: article generator + knowledge Q&A via DeepSeek.
import Layout from "../layouts/Layout.astro";
import Studio from "../components/Studio";
import { readFileSync, readdirSync } from "node:fs";
import { join } from "node:path";

interface ArticleData {
  title: string;
  description: string;
  content: string;
}

/**
 * Clean MDX content for AI consumption:
 * - Strip PascalCase JSX component tags (keep inner text for containers)
 * - Remove JSX comments and imports
 * - Preserve markdown and HTML tags (lowercase)
 */
function cleanMdxForAI(raw: string): string {
  let text = raw;

  // Remove frontmatter
  text = text.replace(/^---[\s\S]*?---\n?/, "");

  // Remove import statements
  text = text.replace(/^import\s+.*$/gm, "");

  // Remove JSX comments {/* ... */}
  text = text.replace(/\{\/\*\s*[\s\S]*?\*\/\}/g, "");

  // Remove self-closing PascalCase components: <DataChart ... />, <ArticleTag ... />
  text = text.replace(/<[A-Z][A-Za-z]*[^>]*?\/\s*>/g, "");

  // Remove opening PascalCase component tags, keep attributes text: <HoverDetail term="x" href="y">
  // But NOT the closing tags — handle separately
  // Strategy: replace opening <Component ...> and closing </Component> with nothing
  text = text.replace(/<\/[A-Z][A-Za-z]*\s*>/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*\s[^>]*?>/g, "");

  // Remove lone opening PascalCase tags without attributes (unlikely but safe)
  text = text.replace(/<[A-Z][A-Za-z]*>/g, "");

  // Remove JSX expressions {value} but NOT markdown link references
  text = text.replace(/\{[^}]*?\}/g, "");

  // Clean up excess whitespace
  text = text.replace(/\n{3,}/g, "\n\n");
  text = text.replace(/^\s*\n/gm, "");

  return text.trim();
}

// Discover all .mdx files in src/pages
const articles: ArticleData[] = [];
const pagesDir = join(process.cwd(), "src", "pages");

try {
  const files = readdirSync(pagesDir).filter((f) => f.endsWith(".mdx"));
  for (const file of files) {
    const fullPath = join(pagesDir, file);
    const text = readFileSync(fullPath, "utf-8");

    // Extract frontmatter
    const fmMatch = text.match(/^---\r?\n([\s\S]*?)\r?\n---/);
    if (!fmMatch) continue;

    const fm = fmMatch[1];
    const titleMatch = fm.match(/title:\s*["'](.+?)["']/);
    const descMatch = fm.match(/description:\s*["'](.+?)["']/);

    // Clean the body for AI
    const body = cleanMdxForAI(text);

    articles.push({
      title: titleMatch?.[1] || file.replace(/\.mdx$/, ""),
      description: descMatch?.[1] || "",
      content: body,
    });
  }
} catch (e) {
  // If readdir fails, build without articles
}

// Read writing guide
let guideRaw = "";
try {
  const guidePath = join(process.cwd(), "NOTE_WRITING_GUIDE.md");
  guideRaw = readFileSync(guidePath, "utf-8");
} catch {}

// API key from env (PUBLIC_ prefix makes it available client-side)
const apiKey = import.meta.env.PUBLIC_DEEPSEEK_API_KEY || "";
---

<Layout
  title="Studio"
  description="AI-powered article generator & knowledge Q&A"
>
  <Studio
    articlesJson={JSON.stringify(articles)}
    writingGuide={guideRaw}
    apiKey={apiKey}
    client:load
  />
</Layout>
