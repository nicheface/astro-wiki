---
// ===== Studio.astro — Password-protected knowledge Q&A =====
import Layout from "../layouts/Layout.astro";
import Studio from "../components/Studio";
import { readFileSync, readdirSync } from "node:fs";
import { join } from "node:path";

interface ArticleData {
  title: string;
  description: string;
  href: string;
  content: string;
}

function cleanMdxForAI(raw: string): string {
  let text = raw;
  text = text.replace(/^---[\s\S]*?---\n?/, "");
  text = text.replace(/^import\s+.*$/gm, "");
  text = text.replace(/\{\/\*\s*[\s\S]*?\*\/\}/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*[^>]*?\/\s*>/g, "");
  text = text.replace(/<\/[A-Z][A-Za-z]*\s*>/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*\s[^>]*?>/g, "");
  text = text.replace(/<[A-Z][A-Za-z]*>/g, "");
  text = text.replace(/\{[^}]*?\}/g, "");
  text = text.replace(/\n{3,}/g, "\n\n");
  text = text.replace(/^\s*\n/gm, "");
  return text.trim();
}

const articles: ArticleData[] = [];
const pagesDir = join(process.cwd(), "src", "pages");

try {
  const files = readdirSync(pagesDir).filter((f) => f.endsWith(".mdx"));
  for (const file of files) {
    const text = readFileSync(join(pagesDir, file), "utf-8");
    const fmMatch = text.match(/^---\r?\n([\s\S]*?)\r?\n---/);
    if (!fmMatch) continue;
    const fm = fmMatch[1];
    articles.push({
      title: (fm.match(/title:\s*["'](.+?)["']/) || [])[1] || file.replace(/\.mdx$/, ""),
      description: (fm.match(/description:\s*["'](.+?)["']/) || [])[1] || "",
      href: (fm.match(/activePath:\s*["'](.+?)["']/) || [])[1] || "",
      content: cleanMdxForAI(text),
    });
  }
} catch {}

const apiKey = import.meta.env.PUBLIC_DEEPSEEK_API_KEY || "";
---

<Layout title="Studio" description="Password-protected knowledge Q&A">
  <Studio articlesJson={JSON.stringify(articles)} apiKey={apiKey} client:load />
</Layout>
