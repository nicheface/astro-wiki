---
import Layout from "../layouts/Layout.astro";
import { articles } from "../data/articles";

// Server-side tag filtering via ?tag=xxx&tag=yyy
const url = new URL(Astro.request.url);
const activeTags = url.searchParams.getAll("tag");

const filtered = activeTags.length > 0
  ? articles.filter((a) => activeTags.every((t) => a.tags.includes(t)))
  : articles;
---

<Layout
  title="Noösphere"
  description="知识库消隐之处，认知开始呼吸。"
>
  <!-- Hero -->
  <header class="not-prose mb-12">
    <div class="space-y-6">
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-zinc-900 leading-tight">
        Noösphere
        <span class="block text-2xl sm:text-3xl font-normal text-zinc-400 mt-3 leading-relaxed">
          当界面没入知觉，思想开始低语。
        </span>
      </h1>
      <p class="text-xl text-zinc-500 leading-loose max-w-2xl">
        一个静默生长的认知拓扑。AI 充当你的外置皮层——知识不再被「管理」，它只是恰好在你需要时涌现。
      </p>
    </div>
  </header>

  <!-- Article List -->
  <section class="not-prose">
    {activeTags.length > 0 && (
      <div class="flex items-center gap-2 mb-6">
        <span class="text-sm text-zinc-500 dark:text-slate-400">标签筛选：</span>
        {activeTags.map((t) => (
          <span class="px-2.5 py-0.5 rounded-lg text-xs font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400">{t}</span>
        ))}
        <a href="/astro-wiki/" class="text-xs text-zinc-400 hover:text-zinc-600 dark:text-slate-500 dark:hover:text-slate-300 transition-colors">✕ 清除</a>
      </div>
    )}

    {filtered.length === 0 ? (
      <p class="text-sm text-zinc-400 dark:text-slate-500">没有匹配的文章。</p>
    ) : (
      <div class="space-y-4">
        {filtered.map((a) => (
          <a
            href={a.href}
            class="block p-5 rounded-2xl border border-zinc-100 dark:border-slate-800 hover:border-zinc-200 dark:hover:border-slate-700 hover:shadow-[0_4px_20px_rgb(0,0,0,0.04)] transition-all duration-300"
          >
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <h3 class="text-lg font-semibold text-zinc-800 dark:text-slate-200 leading-snug">
                  {a.title}
                </h3>
                <p class="text-sm text-zinc-500 dark:text-slate-400 mt-1.5 leading-relaxed">
                  {a.description}
                </p>
              </div>
              <time class="flex-shrink-0 text-xs text-zinc-400 dark:text-slate-500 mt-1" datetime={a.date}>
                {a.date.slice(5)}
              </time>
            </div>
            <div class="flex flex-wrap gap-1 mt-3">
              {a.tags.slice(0, 4).map((t: string) => (
                <span class="px-2 py-0.5 rounded-md text-[10px] bg-zinc-100 dark:bg-slate-800 text-zinc-500 dark:text-slate-400">
                  {t}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>
</Layout>
