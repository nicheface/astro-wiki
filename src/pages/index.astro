---
import Layout from "../layouts/Layout.astro";
import TagFilter from "../components/TagFilterWrapper.astro";
import { articles } from "../data/articles";
---

<Layout
  title="Digital Garden"
  description="知识库消隐之处，认知开始呼吸。"
>
  <!-- Hero Section -->
  <header class="not-prose mb-16">
    <div class="space-y-6">
      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight text-zinc-900 leading-tight">
        数字花园
        <span class="block text-2xl sm:text-3xl font-normal text-zinc-400 mt-3 leading-relaxed">
          当界面没入知觉，思想开始低语。
        </span>
      </h1>
      <p class="text-xl text-zinc-500 leading-loose max-w-2xl">
        一个静默生长的认知拓扑。AI 充当你的外置皮层——知识不再被「管理」，它只是恰好在你需要时涌现。
      </p>
      <a
        href="/astro-wiki/studio"
        class="inline-block mt-4 px-4 py-1.5 rounded-full text-xs font-medium text-zinc-400 dark:text-slate-500 border border-zinc-200 dark:border-slate-700 hover:text-zinc-600 dark:hover:text-slate-300 hover:border-zinc-300 dark:hover:border-slate-600 transition-all duration-300"
      >
        Studio
      </a>
    </div>
  </header>

  <!-- Tag Filter + Article List (single interactive component) -->
  <section class="not-prose">
    <TagFilter articles={articles} />
  </section>
</Layout>
