---
import Layout from "../layouts/Layout.astro";
import { ALL_TAGS } from "../data/tags";
import { articles } from "../data/articles";

const tagCounts = new Map<string, number>();
for (const a of articles) {
  for (const t of a.tags) {
    tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
  }
}

const l1Tags = ALL_TAGS.filter((t) => t.level === 1 && tagCounts.has(t.key));
const l2Tags = ALL_TAGS.filter((t) => t.level === 2 && tagCounts.has(t.key));
const l3Tags = ALL_TAGS.filter((t) => t.level === 3 && tagCounts.has(t.key));
---

<Layout title="标签" description="Noösphere 标签体系">
  <div id="tags-page" class="not-prose">
    <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-slate-100 mb-2">标签</h1>
    <p class="text-sm text-zinc-500 dark:text-slate-400 mb-6">点击标签筛选文章，支持多选组合（AND 逻辑）。</p>

    <!-- Active filter bar -->
    <div id="active-bar" class="mb-8 hidden">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs text-zinc-500 dark:text-slate-400">当前筛选：</span>
        <div id="active-tags" class="flex flex-wrap gap-1"></div>
        <a href="/astro-wiki/tags" class="text-xs text-zinc-400 hover:text-zinc-600 dark:text-slate-500 dark:hover:text-slate-300 ml-2">清除全部</a>
      </div>
      <a id="view-results" href="/astro-wiki/" class="inline-flex items-center gap-1 px-4 py-2 rounded-xl text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 transition-all">
        查看文章 →
      </a>
    </div>

    <!-- Level 1 -->
    <section class="mb-8">
      <h2 class="text-xs font-semibold text-zinc-400 dark:text-slate-500 uppercase tracking-widest mb-3">一级 · 领域</h2>
      <div class="flex flex-wrap gap-2">
        {l1Tags.map((t) => (
          <button data-tag={t.key} class="tag-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-xl bg-zinc-100 dark:bg-slate-800 text-sm font-medium text-zinc-700 dark:text-slate-300 hover:bg-zinc-200 dark:hover:bg-slate-700 transition-all">
            {t.label}
            <span class="text-xs text-zinc-400 dark:text-slate-500">{tagCounts.get(t.key)}</span>
          </button>
        ))}
      </div>
    </section>

    <!-- Level 2 -->
    <section class="mb-8">
      <h2 class="text-xs font-semibold text-zinc-400 dark:text-slate-500 uppercase tracking-widest mb-3">二级 · 主题</h2>
      <div class="space-y-4">
        {l1Tags.map((l1) => {
          const children = l2Tags.filter((t) => t.parent === l1.key);
          if (children.length === 0) return null;
          return (
            <div>
              <p class="text-xs text-zinc-400 dark:text-slate-500 mb-1.5 ml-1">{l1.label}</p>
              <div class="flex flex-wrap gap-1.5">
                {children.map((t) => (
                  <button data-tag={t.key} class="tag-btn inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-zinc-50 dark:bg-slate-900 border border-zinc-100 dark:border-slate-800 text-sm text-zinc-600 dark:text-slate-400 hover:border-zinc-200 dark:hover:border-slate-700 hover:text-zinc-800 dark:hover:text-slate-200 transition-all">
                    {t.label}
                    <span class="text-[10px] text-zinc-400 dark:text-slate-500">{tagCounts.get(t.key)}</span>
                  </button>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Level 3 -->
    <section class="mb-8">
      <h2 class="text-xs font-semibold text-zinc-400 dark:text-slate-500 uppercase tracking-widest mb-3">三级 · 具体</h2>
      <div class="space-y-4">
        {l2Tags.map((l2) => {
          const children = l3Tags.filter((t) => t.parent === l2.key);
          if (children.length === 0) return null;
          return (
            <div>
              <p class="text-xs text-zinc-400 dark:text-slate-500 mb-1.5 ml-1">{l2.label}</p>
              <div class="flex flex-wrap gap-1">
                {children.map((t) => (
                  <button data-tag={t.key} class="tag-btn inline-flex items-center gap-1 px-2.5 py-1 rounded-md bg-zinc-50 dark:bg-slate-900 border border-zinc-100 dark:border-slate-800 text-xs text-zinc-500 dark:text-slate-400 hover:border-zinc-300 dark:hover:border-slate-600 hover:text-zinc-700 dark:hover:text-slate-200 transition-all">
                    {t.label}
                    <span class="text-[10px] text-zinc-400 dark:text-slate-500">{tagCounts.get(t.key)}</span>
                  </button>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </div>
</Layout>

<script>
  const params = new URLSearchParams(window.location.search);
  let selected = new Set(params.getAll("tag"));

  function updateUI() {
    const bar = document.getElementById("active-bar");
    const activeTags = document.getElementById("active-tags");
    const results = document.getElementById("view-results");

    // Active bar
    if (selected.size > 0) {
      bar.classList.remove("hidden");
      activeTags.innerHTML = "";
      selected.forEach((t) => {
        const span = document.createElement("span");
        span.className = "inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400";
        span.innerHTML = `${t} <button data-remove="${t}" class="hover:text-red-500 ml-0.5">&times;</button>`;
        activeTags.appendChild(span);
      });

      // Remove buttons
      activeTags.querySelectorAll("[data-remove]").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          selected.delete(btn.getAttribute("data-remove"));
          syncURL();
          updateUI();
        });
      });

      // Results link
      const query = Array.from(selected).map((t) => `tag=${t}`).join("&");
      results.href = `/astro-wiki/?${query}`;
    } else {
      bar.classList.add("hidden");
    }

    // Highlight tags
    document.querySelectorAll(".tag-btn").forEach((btn) => {
      const tag = btn.getAttribute("data-tag");
      if (selected.has(tag)) {
        btn.classList.add("ring-2", "ring-blue-400", "bg-blue-50", "dark:bg-blue-900/20", "text-blue-700", "dark:text-blue-300");
      } else {
        btn.classList.remove("ring-2", "ring-blue-400", "bg-blue-50", "dark:bg-blue-900/20", "text-blue-700", "dark:text-blue-300");
      }
    });
  }

  function syncURL() {
    const newParams = new URLSearchParams();
    selected.forEach((t) => newParams.append("tag", t));
    const qs = newParams.toString();
    window.history.replaceState(null, "", qs ? `?${qs}` : window.location.pathname);
  }

  // Tag click
  document.querySelectorAll(".tag-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.getAttribute("data-tag");
      if (selected.has(tag)) {
        selected.delete(tag);
      } else {
        selected.add(tag);
      }
      syncURL();
      updateUI();
    });
  });

  updateUI();
</script>
